# ─────────────────────────────────────────────────────────────
# theorchestra — environment variables template
# Copy this file to `.env` and fill in the real values.
# Your real `.env` is gitignored; NEVER commit it.
# ─────────────────────────────────────────────────────────────

# Telegram (required if you want the live streamer)
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_GROUP_ID=-100xxxxxxxxxx   # the forum group where pane topics live

# Watcher tuning (optional — defaults in code are sensible)
# WATCHER_POLL_MS=30000
# STUCK_THRESHOLD_MS=600000

# Path overrides (optional)
# VAULT_PATH=./vault
# ORCHESTRATOR_TICK_MS=180000

# Dashboard (Phase 2 — will be added in a later release)
# DASHBOARD_PORT=4200
